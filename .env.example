# ============================================================
# VANTAGE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Authentication ────────────────────────────────────────────
# Generate a strong secret (min 64 chars): python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=your_strong_random_jwt_secret_here_min_64_chars

# ── Database ──────────────────────────────────────────────────
# Credentials used by docker-compose to initialise MongoDB.
MONGO_USER=admin
MONGO_PASSWORD=change_me_strong_password_here

# ── mongo-express (dev profile only) ─────────────────────────
ME_BASICAUTH_USER=me_admin
ME_BASICAUTH_PASSWORD=change_me_me_password_here

# ── MFA Encryption ───────────────────────────────────────────
# Required in production. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MFA_ENCRYPTION_KEY=

# ── SMTP (optional — for password reset emails) ──────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@soc.local
SMTP_TLS=true

# ── Hostname / URL configuration ─────────────────────────────
# Set both variables to your public hostname when deploying behind a
# reverse proxy (Nginx, Cloudflare Tunnel, Tailscale, etc.).
# Example for a named host: https://vantage.it-eam.com
#
# FRONTEND_URL   — base URL embedded in password-reset e-mail links.
# CORS_ORIGINS   — comma-separated list of allowed browser origins.
#                  In production this must match your public hostname exactly.
#                  Multiple origins: ["https://vantage.it-eam.com","https://alt.example.com"]
FRONTEND_URL=http://localhost
CORS_ORIGINS=["http://localhost","http://localhost:5173"]

# ── Cutover override (optional) ──────────────────────────────
# Used by docker-compose.operational-architect.yml when rehearsing the
# canonical frontend on an alternate local port. Keep 80 in normal operation,
# or set 4177 for a local rehearsal.
VANTAGE_FRONTEND_PORT=80

# ── Runtime ──────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Development seed ─────────────────────────────────────────
# Set DEV_SEED_USERS=true to auto-create admin/tech users on startup.
# ONLY valid when ENVIRONMENT=development. The backend REFUSES to boot
# if DEV_SEED_USERS=true in production.
DEV_SEED_USERS=false
DEV_ADMIN_PASSWORD=
DEV_TECH_PASSWORD=
HUNTING_EXECUTION_MODE=auto
HUNTING_SHERLOCK_BINARY=sherlock
HUNTING_ISOLATED_RUNTIME_ENABLED=false
HUNTING_KALI_RUNTIME_ENABLED=false

# ── Threat Intelligence API Keys ─────────────────────────────
VT_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
SHODAN_API_KEY=your_shodan_api_key_here
OTX_API_KEY=your_alienvault_otx_api_key_here
GREYNOISE_API_KEY=your_greynoise_api_key_here
URLSCAN_API_KEY=your_urlscan_api_key_here
BLACKLISTMASTER_API_KEY=your_blacklistmaster_api_key_here
IP2LOCATION_API_KEY=your_ip2location_api_key_here
PULSEDIVE_API_KEY=your_pulsedive_api_key_here
ABUSECH_API_KEY=your_abusech_api_key_here
URLHAUS_API_KEY=your_urlhaus_api_key_here
