# ============================================================
# Threat Intelligence Tool — Environment Variables
# Rename this file to .env and fill in your values.
# Never commit the .env file to version control.
# ============================================================

# --- Authentication ---
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_strong_random_secret_here

# --- Database ---
MONGO_URI=mongodb://admin:iteam_secure_password@localhost:27017/

# --- CORS (comma-separated origins for production) ---
# CORS_ORIGINS=["https://yourdomain.com"]

# --- Runtime ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Threat Intelligence API Keys ---
VT_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
SHODAN_API_KEY=your_shodan_api_key_here
OTX_API_KEY=your_alienvault_otx_api_key_here
GREYNOISE_API_KEY=your_greynoise_api_key_here
URLSCAN_API_KEY=your_urlscan_api_key_here
BLACKLISTMASTER_API_KEY=your_blacklistmaster_api_key_here
PULSEDIVE_API_KEY=your_pulsedive_api_key_here
ABUSECH_API_KEY=your_abusech_api_key_here
