# APP_URL: Optional public URL for self-referential links in local integrations.
APP_URL="http://localhost"

# VITE_PORT: Optional local port for the canonical Operational Architect frontend.
# Defaults to 4177 so it can run in parallel with older local stacks.
VITE_PORT="4177"

# VITE_API_PROXY_TARGET: Optional backend target for the local /api proxy.
# Defaults to the VANTAGE backend in this repository running on 8000.
VITE_API_PROXY_TARGET="http://localhost:8000"
